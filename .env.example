# Google Cloud: habilita "PageSpeed Insights API" y crea una API key restringida a ese API
GOOGLE_PAGESPEED_API_KEY=

# Clave de API de Google AI Studio / Vertex (Gemini)
GEMINI_API_KEY=

# Opcional: modelo (por defecto gemini-2.5-flash). Lista: https://ai.google.dev/gemini-api/docs/models/gemini
# Si ves 404 con un nombre antiguo (p. ej. gemini-1.5-flash), actualiza aquí o borra la variable para usar el default.
GEMINI_MODEL=gemini-2.5-flash

# SEM Creative Lab — visión del PDF (una de las dos; Anthropic tiene prioridad)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Hugging Face — Inference API (text-to-image: FLUX.1 Schnell / SDXL). Cuenta gratuita: cold start; el servidor reintenta automáticamente.
HF_TOKEN=

# URL pública del Hub (invitaciones Auth, redirects). Ej: https://hub.empresa.com
NEXT_PUBLIC_SITE_URL=

# MFA obligatorio para admin/gerencia. true = desactivar comprobación (solo desarrollo).
HUB_MFA_DISABLED=
NEXT_PUBLIC_HUB_MFA_DISABLED=

# Dominios de email corporativos permitidos para altas excepcionales con contraseña (CSV).
# Ej: minervaglobal.es,empresa.com
CORPORATE_EMAIL_DOMAINS=

# Supabase (URL y anon en cliente; service role solo servidor)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
