# Clave de API de Google AI Studio / Vertex (Gemini)
GEMINI_API_KEY=

# Opcional: modelo (por defecto gemini-2.5-flash). Lista: https://ai.google.dev/gemini-api/docs/models/gemini
# Si ves 404 con un nombre antiguo (p. ej. gemini-1.5-flash), actualiza aquí o borra la variable para usar el default.
GEMINI_MODEL=gemini-2.5-flash
